# Telegram bot token from @BotFather
BOT_TOKEN=
# Comma-separated admin telegram ids
ADMIN_IDS=
# Public HTTPS url of the web app (ngrok / cloudflared / domain). Empty = bot sends no WebApp button.
WEBAPP_URL=
# true = allow X-Dev-User header auth for local browser testing
DEV_MODE=false
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./ncoin.db
# Optional: channel for the "subscribe" task (e.g. -1001234567890 and https://t.me/yourchannel)
CHANNEL_ID=
CHANNEL_URL=
